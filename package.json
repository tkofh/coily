{
  "name": "coily",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:vanilla": "turbo run dev --filter=playground-vanilla...",
    "dev:nuxt": "turbo run dev --filter=playground-nuxt...",
    "deps:reinstall": "pnpm dlx rimraf --glob node_modules packages/*/node_modules pnpm-lock.yaml && pnpm install",
    "deps:upgrade": "pnpm update --recursive --latest && pnpm dedupe",
    "lint": "oxlint --fix",
    "lint:report": "oxlint",
    "format": "oxfmt --write .",
    "format:report": "oxfmt --check .",
    "check": "oxlint --fix && oxfmt --write .",
    "check:report": "oxlint && oxfmt --check .",
    "test": "turbo run test",
    "version-packages": "changeset version && pnpm run format"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "turbo": "^2.10.4",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.10.0",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
