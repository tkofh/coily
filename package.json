{
  "name": "coily",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:vanilla": "turbo run dev --filter=playground-vanilla...",
    "dev:nuxt": "turbo run dev --filter=playground-nuxt...",
    "deps:reinstall": "pnpm dlx rimraf --glob node_modules packages/*/node_modules pnpm-lock.yaml && pnpm install",
    "deps:upgrade": "pnpm update --recursive --latest && pnpm dedupe",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "oxlint && oxfmt --check .",
    "publish-packages": "turbo run check build test && changeset version && changeset publish",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vitest-browser-vue": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
