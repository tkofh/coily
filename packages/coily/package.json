{
  "name": "coily",
  "version": "0.12.2",
  "description": "Simulate values using spring physics",
  "homepage": "https://github.com/tkofh/coily#readme",
  "bugs": {
    "url": "https://github.com/tkofh/coily/issues"
  },
  "license": "MIT",
  "author": "Tim Morris <timthewebguy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkofh/coily.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./nuxt": "./dist/nuxt.js",
    "./vue": "./dist/vue.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "tsdown",
    "build": "tsdown",
    "check": "tsc -p .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "bench:baseline": "vitest bench --run --outputJson bench-baseline.json",
    "bench:compare": "vitest bench --run --compare bench-baseline.json"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.8",
    "@nuxt/schema": "^4.4.8",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "fast-check": "^4.9.0",
    "happy-dom": "^20.10.6",
    "tsdown": "^0.22.4",
    "typescript": "catalog:",
    "vitest": "^4.1.10",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.39"
  },
  "peerDependencies": {
    "@nuxt/kit": "^4.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    }
  }
}
